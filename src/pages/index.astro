          <a href="/" class="flex items-center gap-3 mb-4">
            <img src="/img/logo.svg" alt="Stay True" class="h-7 w-7" />
          </a>
          <p class="text-sm text-fg-muted leading-relaxed mb-3">
            Estudio de desarrollo digital mexicano. Construimos software que perdura.
          </p>
          <p class="text-xs text-fg-muted flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none"
              stroke="#22c55e" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            Cancún, Quintana Roo, México
          </p>
        </div>
        <div>
          <div class="text-[10px] font-mono text-accent tracking-widest uppercase mb-5">Servicios</div>
          <ul class="space-y-3">
            {["Desarrollo Web", "Apps Móviles", "Apps de Escritorio"].map(s => (
              <li><a href="#servicios" class="text-sm text-fg-muted hover:text-fg transition-colors">{s}</a></li>
            ))}
          </ul>
        </div>
        <div>
          <div class="text-[10px] font-mono text-accent tracking-widest uppercase mb-5">Empresa</div>
          <ul class="space-y-3">
            {([["Proyectos", "#proyectos"], ["Proceso", "#proceso"], ["Contacto", "#contacto"]] as const).map(([label, href]) => (
              <li><a href={href} class="text-sm text-fg-muted hover:text-fg transition-colors">{label}</a></li>
            ))}
          </ul>
        </div>
        <div>
          <div class="text-[10px] font-mono text-accent tracking-widest uppercase mb-5">Contacto</div>
          <ul class="space-y-3">
            <li>
              <a href="https://wa.me/529981169584" target="_blank" rel="noopener noreferrer"
                class="text-sm text-fg-muted hover:text-fg transition-colors">
                +52 998 116 9584
              </a>
            </li>
            <li>
              <a href="mailto:kabiralberto10@gmail.com"
                class="text-sm text-fg-muted hover:text-fg transition-colors">
                kabiralberto10@gmail.com
              </a>
            </li>
          </ul>
        </div>
      </div>
      <div class="border-t border-white/[0.06] pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
        <p class="text-xs text-fg-muted">© 2025 Stay True. Todos los derechos reservados.</p>
        <div class="flex items-center gap-1.5 text-xs text-fg-muted">
          <span>Hecho con precisión.</span>
          <span class="text-accent">◆</span>
          <span>Stay True.</span>
        </div>
      </div>
    </div>
  </footer>

</body>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import Lenis from 'lenis';

  gsap.registerPlugin(ScrollTrigger);

  // ── Lenis smooth scroll ────────────────────────────────────
  const lenis = new Lenis({ duration: 1.2 });
  lenis.on('scroll', ScrollTrigger.update);
  gsap.ticker.add((time) => lenis.raf(time * 1000));
  gsap.ticker.lagSmoothing(0);

  // ── Scroll progress bar ────────────────────────────────────
  gsap.to('#scroll-progress', {
    scaleX: 1, ease: 'none',
    scrollTrigger: { start: 'top top', end: 'max', scrub: 0 },
  });

  // ── Navbar border ─────────────────────────────────────────
  const navbar = document.getElementById('navbar');
  ScrollTrigger.create({
    start: 'top -1',
    onUpdate: (self) => {
      if (navbar) navbar.style.borderColor = self.progress > 0
        ? 'rgba(255,255,255,0.09)'
        : 'rgba(255,255,255,0.06)';
    },
  });

  // ── Scroll animations (reduced-motion aware) ──────────────
  const mm = gsap.matchMedia();

  mm.add('(prefers-reduced-motion: no-preference)', () => {

    // ── Hero entrance ──────────────────────────────────────
    const heroText   = document.querySelector<HTMLElement>('.hero-parallax-text');
    const heroVisual = document.querySelector<HTMLElement>('.hero-parallax-visual');
    if (heroText) {
      gsap.from(gsap.utils.toArray<HTMLElement>(heroText.children), {
        opacity: 0, y: 32, duration: 0.9,
        stagger: 0.12, ease: 'power3.out', delay: 0.1, clearProps: 'all',
      });
    }
    if (heroVisual) {
      gsap.from(heroVisual, {
        opacity: 0, x: 48, duration: 1,
        ease: 'power3.out', delay: 0.35, clearProps: 'all',
      });
    }

    // ── Stats counter ──────────────────────────────────────
    document.querySelectorAll<HTMLElement>('[data-counter]').forEach(el => {
      const target = parseInt(el.dataset.counter || '0', 10);
      const prefix = el.dataset.prefix || '';
      el.textContent = prefix + '0';
      const obj = { val: 0 };
      ScrollTrigger.create({
        trigger: el, start: 'top 88%',
        onEnter: () => gsap.to(obj, {
          val: target, duration: 1.4, ease: 'power2.out',
          onUpdate: () => { el.textContent = prefix + Math.round(obj.val); },
        }),
      });
    });

    // ── Helper: section header stagger ─────────────────────
    function animateHeader(selector: string) {
      const el = document.querySelector(selector);
      if (!el) return;
      gsap.from(gsap.utils.toArray<HTMLElement>(el.children), {
        opacity: 0, y: 28, duration: 0.75, stagger: 0.1, ease: 'power3.out', clearProps: 'all',
        scrollTrigger: { trigger: el, start: 'top 85%', toggleActions: 'play none none none' },
      });
    }

    // ── SERVICIOS — clip-path wipe upward per card ─────────
    animateHeader('#servicios .section-header');
    gsap.utils.toArray<HTMLElement>('#servicios .card-spotlight').forEach((card, i) => {
      gsap.fromTo(card,
        { clipPath: 'inset(0 0 100% 0 round 1rem)' },
        {
          clipPath: 'inset(0 0 0% 0 round 1rem)',
          duration: 0.7, ease: 'expo.out', clearProps: 'clip-path',
          delay: i * 0.12,
          scrollTrigger: { trigger: '#servicios .grid', start: 'top 80%', toggleActions: 'play none none none' },
        }
      );
    });

    // ── PROYECTOS — scrub-linked horizontal drift per card ──
    animateHeader('#proyectos .section-header');
    gsap.utils.toArray<HTMLElement>('#proyectos .card-spotlight').forEach((card, i) => {
      const fromLeft = i % 2 === 0;
      gsap.fromTo(card,
        { opacity: 0, x: fromLeft ? -60 : 60, rotateY: fromLeft ? -6 : 6 },
        {
          opacity: 1, x: 0, rotateY: 0,
          duration: 0.85, ease: 'expo.out', clearProps: 'opacity,transform',
          scrollTrigger: { trigger: card, start: 'top 88%', toggleActions: 'play none none none' },
        }
      );
    });

    // ── NOSOTROS — scale-in from blur (main) + rotate-in (small) ──
    animateHeader('#nosotros .section-header');
    gsap.fromTo('#bento-main',
      { opacity: 0, scale: 0.92, filter: 'blur(8px)' },
      {
        opacity: 1, scale: 1, filter: 'blur(0px)',
        duration: 1, ease: 'expo.out', clearProps: 'opacity,transform,filter',
        scrollTrigger: { trigger: '#bento-main', start: 'top 82%', toggleActions: 'play none none none' },
      }
    );
    gsap.utils.toArray<HTMLElement>('#nosotros .card-spotlight:not(#bento-main)').forEach((card, i) => {
      gsap.fromTo(card,
        { opacity: 0, y: 40, rotate: i % 2 === 0 ? -1.5 : 1.5 },
        {
          opacity: 1, y: 0, rotate: 0,
          duration: 0.7, ease: 'expo.out', clearProps: 'opacity,transform',
          delay: i * 0.08,
          scrollTrigger: { trigger: '#nosotros .grid', start: 'top 78%', toggleActions: 'play none none none' },
        }
      );
    });

    // ── STACK — sequential fade-up, crisp expo.out ─────────
    animateHeader('#stack .section-header');
    gsap.from('#stack .grid > div', {
      opacity: 0, y: 18, scale: 0.92, duration: 0.5,
      stagger: { each: 0.05, from: 'start' },
      ease: 'expo.out', clearProps: 'opacity,transform',
      scrollTrigger: { trigger: '#stack .grid', start: 'top 85%', toggleActions: 'play none none none' },
    });

    // ── PROCESO — slide from right + glow ──────────────────
    animateHeader('#proceso .section-header');
    gsap.utils.toArray<HTMLElement>('.process-step').forEach((card, i) => {
      gsap.from(card, {
        opacity: 0, x: 70, duration: 0.75, ease: 'expo.out', clearProps: 'opacity,transform',
        delay: i * 0.12,
        scrollTrigger: { trigger: '#proceso .grid', start: 'top 78%', toggleActions: 'play none none none' },
      });
      ScrollTrigger.create({
        trigger: card, start: 'top 68%',
        onEnter: () => {
          card.style.borderColor = 'rgba(34,197,94,0.28)';
          card.style.boxShadow   = '0 0 0 1px rgba(34,197,94,0.1), 0 4px 32px rgba(0,0,0,0.32), 0 0 28px rgba(34,197,94,0.07)';
          const num = card.querySelector<HTMLElement>('.step-number');
          if (num) num.style.color = 'rgba(34,197,94,0.38)';
        },
      });
    });

    // ── CONTACTO — clip-path wipe from bottom + stagger ────
    const ctaInner = document.querySelector<HTMLElement>('#contacto .relative.max-w-4xl');
    if (ctaInner) {
      gsap.fromTo(ctaInner,
        { clipPath: 'inset(100% 0 0% 0)' },
        {
          clipPath: 'inset(0% 0 0% 0)',
          duration: 1, ease: 'expo.out', clearProps: 'clip-path',
          scrollTrigger: { trigger: '#contacto', start: 'top 75%', toggleActions: 'play none none none' },
        }
      );
      gsap.from(gsap.utils.toArray<HTMLElement>(ctaInner.children), {
        opacity: 0, y: 30, duration: 0.7, stagger: 0.1, ease: 'power3.out', clearProps: 'opacity,transform',
        delay: 0.3,
        scrollTrigger: { trigger: '#contacto', start: 'top 75%', toggleActions: 'play none none none' },
      });
    }
  });

  // ── Hero parallax — desktop only ──────────────────────────
  mm.add('(prefers-reduced-motion: no-preference) and (min-width: 768px)', () => {
    const heroSection = document.querySelector('section');
    if (!heroSection) return;
    gsap.to('.hero-parallax-text', {
      y: -60, ease: 'none', immediateRender: false,
      scrollTrigger: { trigger: heroSection, start: 'top top', end: 'bottom top', scrub: true },
    });
    gsap.to('.hero-parallax-visual', {
      y: 40, ease: 'none', immediateRender: false,
      scrollTrigger: { trigger: heroSection, start: 'top top', end: 'bottom top', scrub: true },
    });
  });

  // ── Mobile menu ────────────────────────────────────────────
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const iconOpen   = document.getElementById('icon-open');
  const iconClose  = document.getElementById('icon-close');

  menuToggle?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
  });
  document.querySelectorAll('.mobile-nav-link').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
    });
  });

  // ── Card spotlight ─────────────────────────────────────────
  document.querySelectorAll<HTMLElement>('.card-spotlight').forEach(card => {
    card.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = card.getBoundingClientRect();
      card.style.setProperty('--mouse-x', `${e.clientX - rect.left}px`);
      card.style.setProperty('--mouse-y', `${e.clientY - rect.top}px`);
    });
  });

  // ── Anchor scroll via Lenis ────────────────────────────────
  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', (e) => {
      const href = anchor.getAttribute('href');
      if (!href || href === '#') return;
      const target = document.querySelector<HTMLElement>(href);
      if (target) {
        e.preventDefault();
        lenis.scrollTo(target, { offset: -64 }); // offset for navbar height
      }
    });
  });
</script>

</html>
