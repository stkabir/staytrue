---
import '../styles/global.css';

const services = [
  {
    title: "Desarrollo Web",
    description:
      "Aplicaciones web de alto rendimiento. SPAs, SSR, plataformas SaaS, dashboards, e-commerce y portales institucionales — arquitectura moderna, resultados medibles.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>`,
    tags: ["React", "Astro.js", "Laravel", "Node.js"],
    tagColor: { text: "rgba(34,197,94,0.85)", border: "rgba(34,197,94,0.18)", bg: "rgba(34,197,94,0.06)" },
    iconBg: "rgba(34,197,94,0.12)",
    iconBorder: "rgba(34,197,94,0.22)",
    hoverGrad: "rgba(34,197,94,0.05)",
  },
  {
    title: "Apps Móviles",
    description:
      "Aplicaciones iOS y Android de calidad nativa. Eficiencia multiplataforma sin sacrificar rendimiento, animaciones fluidas ni la experiencia propia de cada sistema.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>`,
    tags: ["React Native", "Expo", "iOS", "Android"],
    tagColor: { text: "rgba(16,185,129,0.85)", border: "rgba(16,185,129,0.18)", bg: "rgba(16,185,129,0.06)" },
    iconBg: "rgba(16,185,129,0.12)",
    iconBorder: "rgba(16,185,129,0.22)",
    hoverGrad: "rgba(16,185,129,0.05)",
  },
  {
    title: "Apps de Escritorio",
    description:
      "Software de escritorio rápido y ligero para Windows, macOS y Linux. Tecnología web con integración nativa al sistema — listo para instalador, funciona sin conexión.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#84cc16" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
    tags: ["Tauri", "Electron", "Windows", "macOS", "Linux"],
    tagColor: { text: "rgba(132,204,22,0.85)", border: "rgba(132,204,22,0.18)", bg: "rgba(132,204,22,0.06)" },
    iconBg: "rgba(132,204,22,0.12)",
    iconBorder: "rgba(132,204,22,0.22)",
    hoverGrad: "rgba(132,204,22,0.05)",
  },
];

const bentoFeatures = [
  {
    label: "ENTREGA",
    title: "En tiempo, siempre",
    desc: "Sprints ágiles, hitos claros, cero sorpresas. Entregamos cuando prometemos.",
    span: "md:col-span-2",
    accent: "#10b981",
    accentBg: "rgba(16,185,129,0.15)",
    accentBorder: "rgba(16,185,129,0.25)",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
  },
  {
    label: "TRANSPARENCIA",
    title: "Apertura total",
    desc: "Visibilidad completa en cada sprint. Actualizaciones en tiempo real, comunicación abierta.",
    span: "md:col-span-2",
    accent: "#84cc16",
    accentBg: "rgba(132,204,22,0.15)",
    accentBorder: "rgba(132,204,22,0.25)",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#84cc16" stroke-width="1.5"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>`,
  },
  {
    label: "EXPERIENCIA",
    title: "Dominio fullstack",
    desc: "Del frontend a la base de datos, DevOps a sistemas de diseño — manejamos el stack completo.",
    span: "md:col-span-3",
    accent: "#22c55e",
    accentBg: "rgba(34,197,94,0.15)",
    accentBorder: "rgba(34,197,94,0.25)",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="1.5"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
  },
  {
    label: "ESCALABILIDAD",
    title: "Construido para crecer",
    desc: "De 100 a 1,000,000 usuarios sin reescrituras dolorosas. Arquitectura escalable desde el día uno.",
    span: "md:col-span-3",
    accent: "#6ee7b7",
    accentBg: "rgba(110,231,183,0.15)",
    accentBorder: "rgba(110,231,183,0.25)",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#6ee7b7" stroke-width="1.5"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>`,
  },
];

const techStack = [
  { name: "PHP / Laravel",   color: "#a78bfa" },
  { name: "Astro.js",        color: "#ff5d01" },
  { name: "React",           color: "#61dafb" },
  { name: "Next.js",         color: "#e8efe9" },
  { name: "TypeScript",      color: "#3b82f6" },
  { name: "Node.js",         color: "#4ade80" },
  { name: "Livewire",        color: "#fb7185" },
  { name: "React Native",    color: "#61dafb" },
  { name: "MySQL",           color: "#60a5fa" },
  { name: "API REST",        color: "#22c55e" },
  { name: "Tailwind CSS",    color: "#22d3ee" },
  { name: "Dokploy / CI/CD", color: "#84cc16" },
];

const projects = [
  {
    name: "Verde Caribe",
    description: "Plataforma web para empresa de paisajismo y construcción. Arquitectura desacoplada: Astro.js + Laravel con API REST. Tiempos de carga ~60% más rápidos que SPAs tradicionales.",
    stack: ["Astro.js", "Laravel", "MySQL", "REST API"],
    url: "https://verdecaribe.com",
    isActive: true,
    accent: "#22c55e",
  },
  {
    name: "Brickell News",
    description: "Portal de noticias con sistema de contenidos dinámico, SEO técnico avanzado y carga ultrarrápida.",
    stack: ["Laravel", "Astro.js"],
    url: "https://brickell.news",
    isActive: true,
    accent: "#4ade80",
  },
  {
    name: "Cluby",
    description: "Marketplace completo con pasarela de pago, 3 dashboards por rol, Google Maps API y SEO — activo en producción más de 2 años con múltiples vendedores.",
    stack: ["Laravel", "PHP", "MySQL", "REST API", "Google Maps"],
    url: "https://cluby.mx",
    isActive: true,
    accent: "#10b981",
  },
  {
    name: "Maroma Beach",
    description: "Sitio web para resort de lujo en la Riviera Maya con galería multimedia y sistema de reservas.",
    stack: ["React", "Laravel"],
    url: "https://maromabeach.com/es/",
    isActive: true,
    accent: "#84cc16",
  },
  {
    name: "El Dorado Resort",
    description: "Plataforma web para resort todo incluido en la Riviera Maya. Módulos de destinos, actividades y reservas en línea.",
    stack: ["React", "Laravel"],
    url: "https://www.eldoradosparesorts.com.mx/destino",
    isActive: true,
    accent: "#22c55e",
  },
  {
    name: "Dashboard Ohana",
    description: "Panel administrativo para empresa de transfers turísticos: asignación de choferes, monitoreo de rutas y gestión operativa en tiempo real.",
    stack: ["Laravel", "Livewire", "MySQL"],
    url: "https://ohanatransfers.com",
    isActive: true,
    accent: "#6ee7b7",
  },
  {
    name: "Agua Coecytjal",
    description: "Sistema gubernamental de monitoreo de calidad del agua para el Gobierno de Jalisco: +50 cuerpos de agua, estadísticas comparativas y reportes.",
    stack: ["Laravel", "PHP", "MySQL"],
    url: "https://l.coecytjal.org.mx",
    isActive: true,
    accent: "#38bdf8",
  },
  {
    name: "Mujeres Rurales",
    description: "Sistema de otorgamiento de créditos para el Gobierno de CDMX. Flujos complejos de validación y roles granulares de acceso.",
    stack: ["Laravel", "Livewire", "MySQL"],
    url: "https://cdmx.gob.mx",
    isActive: false,
    accent: "#a78bfa",
  },
  {
    name: "Lomas Travel",
    description: "Sistema web para agencia de viajes: gestión de reservas, catálogos de destinos y panel administrativo completo.",
    stack: ["Laravel", "MySQL"],
    url: "https://lomastravel.com",
    isActive: true,
    accent: "#fb923c",
  },
  {
    name: "Azzure Condos",
    description: "Landing page estática de alta performance para desarrollo inmobiliario de lujo en la Riviera Maya.",
    stack: ["Astro.js"],
    url: "https://azzurecondos.com",
    isActive: true,
    accent: "#84cc16",
  },
  {
    name: "Cotizador Crédito",
    description: "Simulador interactivo de crédito financiero con cálculos en tiempo real y UX optimizada para conversión.",
    stack: ["Astro.js", "React"],
    url: "https://simulador-credito-ulises.netlify.app",
    isActive: true,
    accent: "#4ade80",
  },
  {
    name: "México Me Necesita",
    description: "Plataforma institucional con sistema de autenticación, roles y permisos granulares para múltiples tipos de usuario.",
    stack: ["PHP", "MySQL"],
    url: "https://mmn.org.mx",
    isActive: true,
    accent: "#10b981",
  },
];

const processSteps = [
  {
    step: "01",
    title: "Descubrimiento",
    desc: "Nos sumergimos en tus requisitos, usuarios y objetivos para definir un alcance claro y criterios de éxito medibles.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>`,
  },
  {
    step: "02",
    title: "Diseño",
    desc: "Wireframes, prototipos y diseños de alta fidelidad revisados y aprobados antes de escribir una línea de código.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>`,
  },
  {
    step: "03",
    title: "Desarrollo",
    desc: "Sprints ágiles con demos semanales. Visibilidad total del avance — sin cajas negras, sin sorpresas.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
  },
  {
    step: "04",
    title: "Lanzamiento y Soporte",
    desc: "Despliegue controlado, monitoreo continuo y soporte sostenido. Seguimos contigo mucho después del go-live.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`,
  },
];
---
<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" href="/favicon.ico" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content="Stay True — Estudio de desarrollo digital con sede en Cancún, México. Construimos software web, móvil y de escritorio de alto impacto." />
  <title>Stay True — Estudio de Desarrollo Digital · Cancún, México</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
</head>

<body class="bg-canvas text-fg font-sans antialiased overflow-x-hidden">

  <div id="scroll-progress" aria-hidden="true"></div>

  <!-- ══════════════════════════════════════
       LAYERED BACKGROUND SYSTEM
  ══════════════════════════════════════ -->
  <div class="fixed inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute inset-0"
      style="background: radial-gradient(ellipse at top center, #0b1e0e 0%, #030704 50%, #010402 100%);">
    </div>
    <div class="absolute inset-0 opacity-[0.018]"
      style="background-image: radial-gradient(rgba(255,255,255,0.55) 1px, transparent 1px);
             background-size: 32px 32px;">
    </div>
    <div class="absolute -top-48 left-1/2 -translate-x-1/2 w-[1000px] h-[700px] rounded-full animate-blob"
      style="background: radial-gradient(ellipse, rgba(34,197,94,0.13) 0%, transparent 70%); filter: blur(90px);">
    </div>
    <div class="absolute top-1/3 -left-48 w-[600px] h-[500px] rounded-full animate-blob-2"
      style="background: radial-gradient(ellipse, rgba(16,185,129,0.08) 0%, transparent 70%); filter: blur(110px);">
    </div>
    <div class="absolute top-1/2 -right-48 w-[550px] h-[650px] rounded-full animate-blob-3"
      style="background: radial-gradient(ellipse, rgba(132,204,22,0.06) 0%, transparent 70%); filter: blur(120px);">
    </div>
  </div>

  <!-- ══════════════════════════════════════
       NAVBAR
  ══════════════════════════════════════ -->
  <nav id="navbar" class="fixed top-0 left-0 right-0 z-50 border-b border-white/[0.06]">
    <div class="absolute inset-0 bg-canvas/80 backdrop-blur-xl"></div>
    <div class="relative max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">

      <a href="/" class="flex items-center gap-3">
        <img src="/img/logo.svg" alt="Stay True logo" class="h-8 w-8" />
      </a>

      <div class="hidden md:flex items-center gap-8">
        {(["Servicios", "Proyectos", "Proceso", "Contacto"] as const).map((item, i) => {
          const ids = ["servicios", "proyectos", "proceso", "contacto"];
          return (
            <a href={`#${ids[i]}`}
              class="text-sm text-fg-muted hover:text-fg transition-colors duration-200">
              {item}
            </a>
          );
        })}
      </div>

      <div class="flex items-center gap-3">
        <a href="#contacto"
          class="hidden md:inline-flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-medium text-white bg-accent hover:bg-accent-bright transition-all duration-200 active:scale-[0.97]"
          style="box-shadow: 0 0 0 1px rgba(34,197,94,0.5), 0 4px 16px rgba(34,197,94,0.28), inset 0 1px 0 rgba(255,255,255,0.14);">
          Hablemos
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
          </svg>
        </a>
        <button id="menu-toggle" class="md:hidden p-2 text-fg-muted hover:text-fg transition-colors" aria-label="Abrir menú">
          <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
            fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
          <svg id="icon-close" class="hidden" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
            viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>
    </div>

    <div id="mobile-menu" class="hidden md:hidden relative border-t border-white/[0.06]">
      <div class="absolute inset-0 bg-canvas/95 backdrop-blur-xl"></div>
      <div class="relative px-6 py-6 flex flex-col gap-1">
        {([["Servicios","servicios"],["Proyectos","proyectos"],["Proceso","proceso"],["Contacto","contacto"]] as const).map(([label, id]) => (
          <a href={`#${id}`}
            class="mobile-nav-link py-3 text-fg-muted hover:text-fg transition-colors border-b border-white/[0.04] last:border-0">
            {label}
          </a>
        ))}
        <a href="#contacto"
          class="mobile-nav-link mt-4 w-full text-center px-4 py-3 rounded-lg text-sm font-medium text-white bg-accent"
          style="box-shadow: 0 0 0 1px rgba(34,197,94,0.4), 0 4px 14px rgba(34,197,94,0.25);">
          Hablemos
        </a>
      </div>
    </div>
  </nav>

  <!-- ══════════════════════════════════════
       HERO
  ══════════════════════════════════════ -->
  <section class="relative min-h-screen flex items-center pt-16">
    <div class="max-w-7xl mx-auto px-6 py-24 lg:py-32 w-full">
      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <div class="space-y-8 hero-parallax-text">
          <!-- Location badge -->
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-accent/25 bg-accent/[0.07] text-accent text-xs font-mono tracking-widest uppercase">
            <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse-glow inline-block"></span>
            Cancún, México · Web · Móvil · Escritorio
          </div>

          <h1 class="text-5xl md:text-6xl lg:text-[4.5rem] font-semibold tracking-tight leading-[1.04]">
            <span class="block grad-heading">Construimos</span>
            <span class="block shimmer-text">software</span>
            <span class="block grad-heading">que perdura.</span>
          </h1>

          <p class="text-lg md:text-xl text-fg-muted leading-relaxed max-w-lg">
            Estudio de desarrollo digital mexicano con más de 7 años de experiencia.
            Aplicaciones web, apps móviles y software de escritorio — construidos para rendir y escalar.
          </p>

          <div class="flex flex-col sm:flex-row gap-4">
            <a href="#contacto"
              class="inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-lg text-sm font-medium text-white bg-accent hover:bg-accent-bright transition-all duration-200 active:scale-[0.97]"
              style="box-shadow: 0 0 0 1px rgba(34,197,94,0.5), 0 6px 28px rgba(34,197,94,0.3), inset 0 1px 0 rgba(255,255,255,0.14);">
              Iniciar un proyecto
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
              </svg>
            </a>
            <a href="#proyectos"
              class="inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-lg text-sm font-medium text-fg transition-all duration-200 hover:bg-white/[0.05]"
              style="box-shadow: inset 0 0 0 1px rgba(255,255,255,0.09);">
              Ver proyectos
            </a>
          </div>

          <div class="flex gap-8 pt-4 border-t border-white/[0.07]">
            {[
              { val: "+7",   label: "Años de experiencia", counter: 7  },
              { val: "+12",  label: "Proyectos entregados", counter: 12 },
              { val: "MX",   label: "Empresa mexicana" },
            ].map(s => (
              <div>
                <div class="text-2xl font-semibold text-fg"
                     data-counter={s.counter ?? undefined}
                     data-prefix={s.counter ? '+' : undefined}>{s.val}</div>
                <div class="text-xs text-fg-muted mt-1">{s.label}</div>
              </div>
            ))}
          </div>
        </div>

        <!-- Hero visual -->
        <div class="relative hidden lg:flex items-center justify-center h-[520px] hero-parallax-visual">
          <div class="absolute w-72 rounded-2xl overflow-hidden animate-float"
            style="background: linear-gradient(135deg, rgba(255,255,255,0.07) 0%, rgba(255,255,255,0.025) 100%);
                   border: 1px solid rgba(255,255,255,0.09);
                   box-shadow: 0 0 0 1px rgba(255,255,255,0.05), 0 24px 64px rgba(0,0,0,0.55), 0 0 80px rgba(34,197,94,0.07);">
            <div class="px-4 py-3 border-b border-white/[0.06] flex items-center gap-1.5">
              <div class="w-2.5 h-2.5 rounded-full bg-red-400/60"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-yellow-400/60"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-accent/60"></div>
              <span class="ml-3 text-[10px] text-fg-muted font-mono">ProjectController.php</span>
            </div>
            <div class="p-5 font-mono text-[11px] leading-[1.7]">
              <div><span class="text-fg-muted">{"// API REST · Laravel 11"}</span></div>
              <div class="mt-1"><span class="text-accent-lime">class</span>&nbsp;<span class="text-accent-bright">ProjectController</span></div>
              <div><span class="text-fg/40">&#123;</span></div>
              <div class="pl-4"><span class="text-accent-lime">public function</span>&nbsp;<span class="text-accent">index</span><span class="text-fg/40">()</span></div>
              <div class="pl-4"><span class="text-fg/40">&#123;</span></div>
              <div class="pl-8"><span class="text-accent-lime">return</span>&nbsp;<span class="text-accent-mint">response</span><span class="text-fg/40">()-&gt;</span><span class="text-accent">json</span><span class="text-fg/40">(</span></div>
              <div class="pl-12"><span class="text-accent">Project</span><span class="text-fg/40">::</span><span class="text-accent-mint">all</span><span class="text-fg/40">()</span></div>
              <div class="pl-8"><span class="text-fg/40">);</span></div>
